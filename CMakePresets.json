{
  "version": 3,
  "configurePresets": [
    {
      "name": "release",
      "displayName": "Release",
      "binaryDir": "${sourceDir}/build/release",
      "generator": "Ninja",
      "description": "Release: for customers",
      "cacheVariables": {
          "CMAKE_BUILD_TYPE": "Release",
          "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "dev",
      "displayName": "Development",
      "binaryDir": "${sourceDir}/build/dev",
      "generator": "Ninja",
      "description": "Development: fast, but debuggable",
      "cacheVariables": {
          "CMAKE_BUILD_TYPE": "RelWithDebInfo",
          "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "binaryDir": "${sourceDir}/build/debug",
      "generator": "Ninja",
      "description": "Debug: full debugging, but slow",
      "cacheVariables": {
          "CMAKE_BUILD_TYPE": "Debug",
          "CMAKE_CXX_FLAGS_DEBUG": "-g -O0",
          "CMAKE_C_FLAGS_DEBUG": "-g -O0",
          "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "run-r",
      "configurePreset": "release",
      "targets": ["run"]
    },
    {
      "name": "run",
      "configurePreset": "dev",
      "targets": ["run"]
    },
    {
      "name": "run-d",
      "configurePreset": "debug",
      "targets": ["run"]
    }
  ]
}