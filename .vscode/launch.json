{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(lldb-mac) Launch",
            // lldb-dap is provided by msft's LLDB DAP plugin.
            //  https://marketplace.visualstudio.com/items?itemName=llvm-vs-code-extensions.lldb-dap
            "type": "lldb-dap",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            // "program": "/Users/bruceoberg/code/SensorCal/build/debug/src/SensorCal.app/Contents/MacOS/SensorCal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "(lldb-linux) Launch",
            "type": "lldb",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "(msvc) Launch",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "$${command:cmake.launchTargetPath}",
            "cwd": "${workspaceFolder}"
        }
    ]
}